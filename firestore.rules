rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Global Safety Net: default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper to validate document ID is a phone number format
    function isValidId(id) {
      return id is string && id.size() >= 10 && id.size() <= 15 && id.matches('^[0-9]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    // Collection: users
    match /users/{phone} {
      allow get: if isValidId(phone);
      allow create, update: if isValidId(phone) 
        && incoming().phone == phone
        && incoming().name is string && incoming().name.size() <= 100
        && incoming().businessName is string && incoming().businessName.size() <= 100
        && incoming().password is string && incoming().password.size() <= 100;
    }

    // Collection: users_business_data
    match /users_business_data/{phone} {
      allow get: if isValidId(phone);
      allow create, update: if isValidId(phone)
        && incoming().userPhone == phone;
    }
  }
}
